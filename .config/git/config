[user]
	name = SAITOU Keita
	email = keita44.f4@gmail.com
[color]
	ui = auto
	status = auto
	diff = auto
	log = auto
	branch = auto
[alias]
	h = help
	co = checkout
	ci = commit
	cif = commit --amend --no-edit
	st = status --short --branch
	sts = diff --stat
	br = branch
	l = log --graph --date=format:'%Y/%m/%d(%a) %T %z'
	a = add .
	addw = !git diff --ignore-all-space --no-color | git apply --cached
	aw = !git diff --ignore-all-space --no-color | git apply --cached
	addp = add --patch
	ap = add --patch
	diffs = diff --staged
	diffw = diff --color-words
	diff-pure = !git --no-pager diff
	show-pure = !git --no-pager show
	pushf = push --force-with-lease
	blames = blame -s
	cp = cherry-pick
	rbi = rebase --interactive
	tags = tag --list
	fetch1 = !git branch --show-current | xargs --replace='{}' git fetch --depth 1 origin '{}'
	clean-safe = !git clean -ffdx --exclude=\".env\" --exclude=\".envrc\" --exclude=\".mise.toml\" --exclude=\"my.Procfile.dev\" --exclude=\".dir-locals.el\" --exclude=\"AGENT.md\" --exclude=\"CLAUDE.md\" --exclude=\".serena\"
	branch-clean-merged = !git branch --merged | tail +2 | xargs --replace='{}' git branch --delete {}
[core]
	editor = emacsclient
	pager = delta --color-only
[interactive]
	diffFilter = delta --color-only
[delta]
	keep-plus-minus-markers = false
	hunk-header-style = blue bold ul
	file-style = yellow
	plus-style = syntax darkgreen
	plus-emph-style = syntax forestgreen
	minus-style = syntax maroon
	minus-emph-style = syntax crimson
# 日本語 diff をうまく扱う設定
# https://zenn.dev/hnw/articles/b295b0b8c55b0d
	word-diff-regex = "[a-zA-Z0-9_]+|\\p{Hiragana}+|[\\p{Katakana}ー]+|[\\p{Han}〆]+|."
[push]
	autoSetupRemote = true
[merge]
	conflictstyle = zdiff3
[rebase]
	autostash = true
	autosquash = true
	rebaseMerges = true
[blame]
	date=format:%m/%d(%a)%R
[help]
	autocorrect = 1
[rerere]
	enable = true
[commit]
	verbose = true
[diff]
	algorithm = patience
	submodule = log
	context = 7
[pull]
	ff = only
[init]
	defaultBranch = main
[status]
	submoduleSummary = true
[submodule]
	recurse = true
[branch]
	sort = -committerdate
[credential]
	helper = store --file ~/.config/git/credentials
[url "https://github.com/"]
	insteadOf = git@github.com:
[log]
	follow = true
[secrets]
	providers = git secrets --aws-provider
	patterns = (A3T[A-Z0-9]|AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}
	patterns = (\"|')?(AWS|aws|Aws)?_?(SECRET|secret|Secret)?_?(ACCESS|access|Access)?_?(KEY|key|Key)(\"|')?\\s*(:|=>|=)\\s*(\"|')?[A-Za-z0-9/\\+=]{40}(\"|')?
	patterns = (\"|')?(AWS|aws|Aws)?_?(ACCOUNT|account|Account)_?(ID|id|Id)?(\"|')?\\s*(:|=>|=)\\s*(\"|')?[0-9]{4}\\-?[0-9]{4}\\-?[0-9]{4}(\"|')?
	allowed = AKIAIOSFODNN7EXAMPLE
	allowed = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
